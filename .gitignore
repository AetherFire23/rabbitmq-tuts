.idea/**/rider.xml


# =============================================================================
# RIDER
# =============================================================================

## Rider project model
.idea/.idea.*/
## But keep the shared parts
!.idea/.idea.*/.idea/
!.idea/.idea.*/.idea/projectSettingsUpdater.xml
!.idea/.idea.*/.idea/.gitignore
!.idea/.idea.*/.idea/modules.xml
!.idea/.idea.*/.idea/runConfigurations/

## Rider run configurations (keep shared ones, ignore user-local)
.idea/runConfigurations/*.xml
!.idea/runConfigurations/.gitkeep

## Local Rider settings
.idea/codeStyles/codeStyleConfig.xml
.idea/inspectionProfiles/profiles_settings.xml
.idea/*.xml


